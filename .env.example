# Copy to .env and adjust. Phase 1 runs fine WITHOUT Mongo — it falls back to fake events.
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/timeline

# Bearer token required to use the HTTP MCP endpoint at /mcp.
# If unset, /mcp responds 503 (fail closed). Generate one with: openssl rand -hex 24
MCP_TOKEN=
