# Copy to .env and adjust. Phase 1 runs fine WITHOUT Mongo — it falls back to fake events.
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/timeline

# --- /mcp endpoint auth ---

# Public origin of the deployed app, used as the OAuth issuer / resource id.
# On Railway this is derived automatically from RAILWAY_PUBLIC_DOMAIN; set it
# explicitly elsewhere. Locally it defaults to http://localhost:PORT.
# PUBLIC_URL=https://your-app.up.railway.app

# Password for the browser consent screen when connecting an OAuth client
# (e.g. Claude). Falls back to MCP_TOKEN if unset. Generate: openssl rand -hex 24
OAUTH_PASSWORD=

# Optional static OAuth client, for clients that make you paste a client
# id/secret instead of using dynamic registration. Leave blank to rely on
# dynamic client registration (recommended).
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback

# Optional static bearer token accepted by /mcp (handy for CLI/testing).
# Generate: openssl rand -hex 24
MCP_TOKEN=
