if !groups || groups.length === 0
  .empty Nothing coming up.
else
  each g in groups
    section.day-group
      .day-header= g.label
      each e in g.events
        .event(class=(e.allDay ? 'all-day' : '') style='--evt:' + e.color)
          .event-main
            .event-title= e.title
            .event-time= e.timeText
          .event-actions
            button.icon-btn(hx-get='/events/' + e.id + '/edit' hx-target='#dialog' hx-swap='innerHTML' title='Edit') Edit
            button.icon-btn.danger(hx-delete='/events/' + e.id hx-swap='none' hx-confirm='Delete this event?' title='Delete') Delete
