extends layout

block content
  .timeline-viewport#viewport
    //- Timeline switcher: "All" + one chip per timeline, plus the admin link.
    //- Switching is a normal navigation so the poll URL below stays correct.
    nav.switch-bar
      a.chip(class=(!selected ? 'active' : '') href='/') All
      each t in timelines
        a.chip(
          class=(selected && selected.slug === t.slug ? 'active' : '')
          href='/?timeline=' + t.slug
          style='--tl:' + t.color
        )= t.name
      a.chip.admin-link(href='/admin' title='Manage timelines') ⚙

    //- Server-rendered agenda. Polls every 60s so passed events drop off,
    //- and is OOB-swapped by create/update/delete. The poll carries the
    //- active timeline filter so it re-renders the same view.
    .timeline-track#track(hx-get='/events/list' + tq hx-trigger='every 60s' hx-target='#track' hx-swap='innerHTML')
      include partials/agenda

  //- Modal mount point; filled by HTMX for the edit form.
  #dialog

  //- On first load, jump to the next upcoming event so past (uncompleted)
  //- events sit above the fold — scroll up to reach them. Runs once; the 60s
  //- poll re-renders the list but must not yank the user's scroll position.
  script.
    requestAnimationFrame(() => {
      document.getElementById('now-anchor')?.scrollIntoView({ block: 'start' });
    });
